{
  "id": "mintapi",
  "name": "MintAPI",
  "description": "Expose MintAPI paid API endpoints as OpenClaw tools.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": {
        "type": "string",
        "description": "MintAPI base URL, for example https://api.mintapi.dev"
      },
      "signerModule": {
        "type": "string",
        "description": "Path to a signer module that satisfies @mintapi/gateway client requirements"
      },
      "preferredNetworks": {
        "type": "array",
        "description": "Preferred payment networks passed to the MintAPI client",
        "items": {
          "type": "string"
        }
      }
    },
    "required": [
      "signerModule"
    ]
  },
  "contracts": {
    "tools": [
      "mintapi_twitter_user_info",
      "mintapi_twitter_user_timeline",
      "mintapi_twitter_followers",
      "mintapi_twitter_following",
      "mintapi_twitter_search",
      "mintapi_twitter_latest_replies",
      "mintapi_twitter_tweet_info",
      "mintapi_twitter_user_replies",
      "mintapi_twitter_trends",
      "mintapi_youtube_video_info",
      "mintapi_youtube_channel_videos",
      "mintapi_youtube_channel_about",
      "mintapi_youtube_playlist",
      "mintapi_youtube_related",
      "mintapi_youtube_transcript",
      "mintapi_youtube_comments",
      "mintapi_youtube_search"
    ]
  }
}
